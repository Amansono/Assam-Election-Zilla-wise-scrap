import pandas as pd
from bs4 import BeautifulSoup
from selenium import webdriver
from selenium.webdriver.chrome.service import Service
from selenium.webdriver.chrome.options import Options
from selenium.webdriver.support.ui import Select, WebDriverWait
from selenium.webdriver.support import expected_conditions as EC
from selenium.webdriver.common.by import By
from webdriver_manager.chrome import ChromeDriverManager

URL = "https://ermssec.assam.gov.in/panchayat/download-pdf-electoral-roll"
TARGET_DISTRICT = "BARPETA" 
OUTPUT_FILE = r"C:\Users\Mayank\Documents\Final_BARPETA001.xlsx"

def get_driver():
    chrome_options = Options()
    chrome_options.add_argument("--headless")
    chrome_options.add_argument("--disable-gpu")
    chrome_options.add_argument("--no-sandbox")
    chrome_options.add_argument("--lang=as")
    driver = webdriver.Chrome(service=Service(ChromeDriverManager().install()), options=chrome_options)
    return driver

def force_select(driver, select_id, text_value):
    try:
        wait = WebDriverWait(driver, 10)
        dropdown_element = wait.until(EC.presence_of_element_located((By.ID, select_id)))
        
        driver.execute_script(f"""
            var sel = document.getElementById('{select_id}');
            var val = `{text_value}`.trim();
            for (var i = 0; i < sel.options.length; i++) {{
                if (sel.options[i].text.trim() === val) {{
                    sel.selectedIndex = i;
                    sel.dispatchEvent(new Event('change'));
                    return true;
                }}
            }}
            return false;
        """)
        return True
    except:
        return False

def get_options(driver, select_id):
    try:
        WebDriverWait(driver, 7).until(lambda d: len(Select(d.find_element(By.ID, select_id)).options) > 1)
        select_element = Select(driver.find_element(By.ID, select_id))
        return [opt.text.strip() for opt in select_element.options 
                if opt.get_attribute('value') and opt.get_attribute('value') != "0" and "Select" not in opt.text]
    except:
        return []

driver = get_driver()
all_rows = []

print("-" * 149)
print(f"{'ZPC':<20} | {'GP':<20} | {'WARD NAME/NO':<15} | {'POLLING STATION (BOOTH)':<50} | {'COUNT'}")
print("-" * 155)

try:
    driver.get(URL)
    
    if not force_select(driver, "elctn_dist", TARGET_DISTRICT):
        print("District not found.")
        driver.quit()
        exit()

    zpcs = get_options(driver, "zpc")
    for zpc in zpcs:
        force_select(driver, "zpc", zpc)
        gps = get_options(driver, "gp")
        
        for gp in gps:
            force_select(driver, "gp", gp)
            wards = get_options(driver, "pe_ward")
            
            for ward in wards:
                force_select(driver, "pe_ward", ward)
                stations = get_options(driver, "ps")
                
                for ps in stations:
                    all_rows.append({
                        "District": TARGET_DISTRICT,
                        "Zila Parishad": zpc,
                        "Gaon Panchayat": gp,
                        "Ward Name": ward,
                        "Polling Station": ps
                    })
                    print(f"{zpc[:18]:<20} | {gp[:18]:<20} | {ward[:13]:<15} | {ps[:48]:<50} | {len(all_rows)}")

except Exception as e:
    print(f"\nError occurred: {e}")

finally:
    if all_rows:
        df = pd.DataFrame(all_rows)
        df.to_excel(OUTPUT_FILE, index=False)
        print("-" * 155)
        print(f"SUCCESS! Data saved at: {OUTPUT_FILE}")
        print(f"Total Entries Collected: {len(all_rows)}")
    else:
        print("No data was found or collected.")
    driver.quit()

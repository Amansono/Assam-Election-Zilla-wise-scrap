import time
import pandas as pd
import os
from bs4 import BeautifulSoup
from selenium import webdriver
from selenium.webdriver.chrome.service import Service
from selenium.webdriver.chrome.options import Options
from selenium.webdriver.common.by import By
from selenium.webdriver.support.ui import Select, WebDriverWait
from selenium.webdriver.support import expected_conditions as EC
from webdriver_manager.chrome import ChromeDriverManager

def get_unique_filename(base_path, filename):
    name, ext = os.path.splitext(filename)
    final_path = os.path.join(base_path, filename)
    counter = 1
    
    while os.path.exists(final_path):
        final_path = os.path.join(base_path, f"{name} ({counter}){ext}")
        counter += 1
    return final_path

DOCS_PATH = os.path.join(os.path.expanduser("~"), "Documents")
FINAL_FILE = get_unique_filename(DOCS_PATH, "Assam_Boothwise_1stapril_list.xlsx")
SUMMARY_FILE = get_unique_filename(DOCS_PATH, "Assam_zilla_Summary_Report.xlsx")

def get_driver():
    chrome_options = Options()
    chrome_options.add_argument("--headless") 
    chrome_options.add_argument("--window-size=1920,1080")
    chrome_options.add_argument("user-agent=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36")
    return webdriver.Chrome(service=Service(ChromeDriverManager().install()), options=chrome_options)

def get_options_bs4(driver, element_id):
    try:
        WebDriverWait(driver, 15).until(lambda d: len(Select(d.find_element(By.ID, element_id)).options) > 1)
        soup = BeautifulSoup(driver.page_source, 'html.parser')
        select_tag = soup.find('select', {'id': element_id})
        return [opt.text.strip() for opt in select_tag.find_all('option') if "Select" not in opt.text and opt.text.strip() != ""]
    except:
        return []

def force_select(driver, element_id, text):
    wait = WebDriverWait(driver, 15)
    for attempt in range(3):
        try:
            el = wait.until(EC.presence_of_element_located((By.ID, element_id)))
            select_obj = Select(el)
            options = [o.text.strip() for o in select_obj.options]
            if text.strip() in options:
                select_obj.select_by_visible_text(text)
                time.sleep(2.5) 
                return True
        except:
            time.sleep(2)
    return False

print(f"Haan meri jaan data saved: {os.path.basename(FINAL_FILE)}")
driver = get_driver()
url = "https://ermssec.assam.gov.in/panchayat/download-pdf-electoral-roll"
final_list = []

try:
    driver.get(url)
    all_districts = get_options_bs4(driver, "elctn_dist")
    print(f"Found {len(all_districts)} Districts. Starting Single-Process Scraping...\n")

    for idx, dist in enumerate(all_districts, 1):
        print(f"Folder [{idx}/{len(all_districts)}] DIST: {dist}")
        
        driver.get(url) 
        if not force_select(driver, "elctn_dist", dist): continue
        
        zpcs = get_options_bs4(driver, "zpc")
        for zpc in zpcs:
            if not force_select(driver, "zpc", zpc): continue
            
            gps = get_options_bs4(driver, "gp")
            for gp in gps:
                if not force_select(driver, "gp", gp): continue
                
                wards = get_options_bs4(driver, "pe_ward")
                for ward in wards:
                    if not force_select(driver, "pe_ward", ward): continue
                    
                    booths = get_options_bs4(driver, "ps")
                    for b in booths:
                        final_list.append({
                            "District": dist,
                            "Zila_Parishad": zpc,
                            "Gaon_Panchayat": gp,
                            "Ward": ward,
                            "Polling_Station": b
                        })
                print(f"   ∟ GPC: {gp} | ZP: {zpc} | Booths: {len(final_list)}", end='\r')

        if final_list:
            pd.DataFrame(final_list).to_excel(FINAL_FILE, index=False)

except Exception as e:
    print(f"\n Baal Error: {e}")

finally:
    if final_list:
        df = pd.DataFrame(final_list)
        df.to_excel(FINAL_FILE, index=False)
        print(f"\nTotal Records: {len(df)}")
        print(f"Saved to: {FINAL_FILE}")
    
    driver.quit()
